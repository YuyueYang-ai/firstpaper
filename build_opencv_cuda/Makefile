	$(MAKE) $(MAKESILENT) -f CMakeFiles/imgui.dir/build.make CMakeFiles/imgui.dir/viewer/imgui/imgui_widgets.cpp.s
.PHONY : viewer/imgui/imgui_widgets.cpp.s

viewer/imgui_viewer.o: viewer/imgui_viewer.cpp.o
.PHONY : viewer/imgui_viewer.o

# target to build an object file
viewer/imgui_viewer.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/gaussian_viewer.dir/build.make CMakeFiles/gaussian_viewer.dir/viewer/imgui_viewer.cpp.o
.PHONY : viewer/imgui_viewer.cpp.o

viewer/imgui_viewer.i: viewer/imgui_viewer.cpp.i
.PHONY : viewer/imgui_viewer.i

# target to preprocess a source file
viewer/imgui_viewer.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/gaussian_viewer.dir/build.make CMakeFiles/gaussian_viewer.dir/viewer/imgui_viewer.cpp.i
.PHONY : viewer/imgui_viewer.cpp.i

viewer/imgui_viewer.s: viewer/imgui_viewer.cpp.s
.PHONY : viewer/imgui_viewer.s

# target to generate assembly for a file
viewer/imgui_viewer.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/gaussian_viewer.dir/build.make CMakeFiles/gaussian_viewer.dir/viewer/imgui_viewer.cpp.s
.PHONY : viewer/imgui_viewer.cpp.s

